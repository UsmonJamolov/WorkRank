{
  "expo": {
    "name": "WorkRank",
    "slug": "workrank",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2563EB",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.workrank.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB"
      },
      "package": "com.workrank.app"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "WorkRank QR davomat uchun kameradan foydalanadi."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "WorkRank ish rasmlarini yuklash uchun galereyadan foydalanadi."
        }
      ]
    ]
  }
}
